{
  "expo": {
    "name": "VolaNow",
    "slug": "App_mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_VolaNow/Icon_Volanao.png",
    "scheme": "appmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/logo_VolaNow/Icon_Volanao.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CALL_PHONE",
        "android.permission.CALL_PHONE"
      ],
      "package": "com.anonymous.App_mobile"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow VolaNow to access your camera to scan recharge cards."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow VolaNow to access your photos to select a recharge card image."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_VolaNow/Logo_Light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/logo_VolaNow/Logo_Dark.png",
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "853e8f8c-a48c-43cc-a6eb-d499726fb075"
      }
    }
  }
}
